# GitHub token used server-side to query the GraphQL API.
# MVP: a classic Personal Access Token with the `read:user` scope is enough for public data.
# Never commit the real value — .env is gitignored.
GITHUB_TOKEN=

# Neon Postgres connection string (persistent cache + leaderboard).
# Get it from the Neon console → your project → "Connection string".
# Leave empty to run without a DB (cache falls back to in-memory).
DATABASE_URL=

# Feature flag: set to "true" to show the "Embed in your GitHub profile" UI on a
# user page. Off in production for now (left unset), so its live preview never
# fires extra embed requests. Vite tree-shakes the whole block when it's not "true".
VITE_FEATURE_EMBED=
